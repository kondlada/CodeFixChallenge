# AI Agent Configuration
# Copy this file to .env and add your API keys

# Anthropic Claude API Key (Recommended)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI GPT API Key (Alternative)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Model Selection (auto, anthropic, or openai)
# auto = automatically detect based on available API keys
AI_MODEL_PROVIDER=auto

# GitHub Configuration (already configured)
GITHUB_TOKEN=your-github-token-here
GITHUB_REPO=kondlada/CodeFixChallenge
